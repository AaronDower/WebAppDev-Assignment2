{{#if drinks}}

  <table class="ui unstackable striped table">
    <thead>
      <tr>
        <th class="four wide">Drink</th>
        <th class="four wide">Description</th>
        <th class="two wide"> </th>
        <th class="two wide"> </th>
      </tr>
    </thead>
    <tbody>
      
      {{#each drinks}}
      
        {{> listOneDrink drink=this drinkId=../id}}
        {{> editdrink drink=this drinkId=../id}}
                
                <script>
    document.querySelector("#showEdit{{@index}}").addEventListener ('click', () => {
        document.querySelector("#drink{{@index}}").style.display = "none";
        document.querySelector("#edit{{@index}}").style.display = "table-row";
    })
    document.querySelector("#hideEdit{{@index}}").addEventListener ('click', () => {
        document.querySelector("#drink{{@index}}").style.display = "table-row";
        document.querySelector("#edit{{@index}}").style.display = "none";
    })
</script>

      {{/each}}
    
    </tbody>
  </table>

{{else}}
  <h3 class="ui message">
    Empty drink collection!
  </h3>

{{/if}}
