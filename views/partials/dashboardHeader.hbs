  <style>
     section{
      padding-bottom: 20px;
     }
    .dashboard-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 20px;
      background-color: lightsteelblue;
      padding: 20px;
      
     }

    .dashboard-header .title {
      font-size: 2em;
      font-weight: bold;
      color: black;
      margin-bottom: 10px;
    }

    .dashboard-header .ui.form {
      width: 100%;
      max-width: 1000px;
    }

    div.ui.inline.fields {
      background-color: rgb(113, 203, 211);
      padding: 10px;
      
      border: 2px solid black;
    }
  </style>
  
  <section class="dashboard-header">

    <h2 class="title">Drink Collection App Dashboard</h2>

    <form action="/searchCategory" method="GET" class="ui form">
        
      <div class="ui inline fields">
        <div class="field">
          <input type="text" name="searchTerm" placeholder="Search by title..." value="{{search}}">
        </div>

        <div class="field">
          <label>Sort by:</label>
          <select class="ui dropdown" name="sort" onchange="this.form.submit()">
            <option value="title" {{#if titleSelected}}selected{{/if}}>Title</option>
            <option value="numDrinks" {{#if numDrinksSelected}}selected{{/if}}>Number of Drinks</option>
          </select>
        </div>

        <div class="field">
          <label>Order:</label>
          <select class="ui dropdown" name="order" onchange="this.form.submit()">
            <option value="asc" {{#if ascSelected}}selected{{/if}}>↑</option>
            <option value="desc" {{#if descSelected}}selected{{/if}}>↓</option>
          </select>
        </div>
      </div>

    </form>

  </section>
